/* =============================================================================
   LYTE Custom QSS Theme Template
   =============================================================================
   Copy this file to your_themename.qss (e.g. ocean.qss) in the themes folder
   and select it from View → Theme. QSS uses Qt Style Sheet syntax (similar to CSS).

   Useful Qt widget selectors:
   - QWidget, QMainWindow, QDialog
   - QPushButton, QPushButton:hover, QPushButton:pressed, QPushButton:disabled
   - QLineEdit, QPlainTextEdit, QSpinBox, QComboBox
   - QSlider::groove:horizontal, QSlider::handle:horizontal
   - QMenuBar, QMenu, QMenu::item:selected
   - QListWidget, QListWidget::item:selected, QListWidget::item:hover
   - QCheckBox, QCheckBox::indicator, QCheckBox::indicator:checked
   - QScrollBar:vertical, QScrollBar::handle:vertical
   - QGroupBox, QToolTip
   ============================================================================= */

QWidget {
    background-color: #191919;
    color: #dcdcdc;
}

QMainWindow, QDialog {
    background-color: #191919;
}

QMenuBar {
    background-color: #1e1e1e;
    color: #dcdcdc;
}

QMenuBar::item:selected {
    background-color: #507850;
}

QMenu {
    background-color: #232323;
    color: #dcdcdc;
}

QMenu::item:selected {
    background-color: #507850;
}

QPushButton {
    background-color: #3c463c;
    color: #dcdcdc;
    border: 1px solid #465a46;
    border-radius: 8px;
    padding: 8px 16px;
}

QPushButton:hover {
    background-color: #507850;
}

QPushButton:pressed {
    background-color: #649664;
}

QPushButton:disabled {
    background-color: #232323;
    color: gray;
}

QLineEdit, QPlainTextEdit, QTextEdit, QSpinBox, QComboBox {
    background-color: #232323;
    color: #dcdcdc;
    border: 1px solid #465a46;
    border-radius: 8px;
    padding: 6px;
}

QComboBox::drop-down {
    background-color: #3c463c;
    border: none;
}

QComboBox QAbstractItemView {
    background-color: #232323;
    color: #dcdcdc;
}

QSlider::groove:horizontal {
    background: #232323;
    height: 8px;
    border-radius: 4px;
}

QSlider::handle:horizontal {
    background: #649664;
    width: 16px;
    margin: -4px 0;
    border-radius: 8px;
}

QSlider::handle:horizontal:hover {
    background: #78b478;
}

QScrollBar:vertical {
    background: #232323;
    width: 12px;
    border-radius: 6px;
}

QScrollBar::handle:vertical {
    background: #3c463c;
    border-radius: 6px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background: #507850;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}

QListWidget {
    background-color: #232323;
    color: #dcdcdc;
    border: 1px solid #465a46;
    border-radius: 8px;
}

QListWidget::item:selected {
    background-color: #507850;
}

QListWidget::item:hover {
    background-color: #3c463c;
}

QCheckBox {
    color: #dcdcdc;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    border: 1px solid #465a46;
    background-color: #232323;
}

QCheckBox::indicator:checked {
    background-color: #649664;
}

QGroupBox {
    color: #dcdcdc;
    border: 1px solid #465a46;
    border-radius: 8px;
    margin-top: 12px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 4px 8px;
}

QToolTip {
    background-color: #232323;
    color: #dcdcdc;
    border: 1px solid #465a46;
    border-radius: 8px;
    padding: 6px;
}
